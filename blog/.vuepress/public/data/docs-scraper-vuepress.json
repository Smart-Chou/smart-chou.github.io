        "https://codenoob.top/tag", 
        "https://codenoob.top/category", 
        "https://codenoob.top/404.html", 
        "https://codenoob.top/timeline/", 
        "https://codenoob.top/article", 
        "https://codenoob.top/star", 
        "https://codenoob.top/slide", 
        "https://codenoob.top/encrypt", 
        "https://codenoob.top/author.html", 
        "https://codenoob.top/message.html", 
        "https://codenoob.top/friends.html", 
        "https://codenoob.top/projects/", 
        "https://codenoob.top/latest.html", 
        "https://codenoob.top/home.html"
    ],
    "selectors": {
        "lvl0": {
            "selector": ".page-title h1 span",
            "global": true,
            "default_value": "Documentation"
        },
        "lvl1": ".theme-default-content h2",
        "lvl2": ".theme-default-content h3",
        "lvl3": ".theme-default-content h4",
        "lvl4": ".theme-default-content h5",
        "lvl5": ".theme-default-content h6",
